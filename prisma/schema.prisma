generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Prisma 7 removed `url` from the schema. The migration/introspection URL comes
// from prisma.config.ts; the runtime connection comes from the driver adapter
// passed to the PrismaClient constructor in src/lib/db.ts.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// better-auth
//
// These tables are owned by better-auth. The `role`/`banned`/`banReason`/
// `banExpires` and `impersonatedBy` fields come from the admin plugin, and
// `rateLimit` exists because rateLimit.storage is "database".
// ---------------------------------------------------------------------------

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // username plugin: `username` is the normalized (lowercased) unique handle;
  // `displayUsername` preserves the casing the user typed. Both are optional in
  // the plugin's schema; every user gets one assigned at creation (a random
  // handle) via the databaseHook in auth.ts. Maintained here by hand because the
  // better-auth CLI can't parse our server-only config.
  username        String? @unique
  displayUsername String?
  /// Ours, not better-auth's: a username may be changed exactly once. Set true
  /// the first time the user picks a custom handle, after which the field locks.
  usernameChanged Boolean @default(false)

  // admin plugin
  role       String?
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  /// The public leaderboard is on by default, so this is an opt-OUT: a user who
  /// sets it keeps their name off a page anyone can read. Not a better-auth
  /// field — it is ours, and better-auth never writes it.
  leaderboardOptOut Boolean @default(false)

  sessions          Session[]
  accounts          Account[]
  interviewSessions InterviewSession[]
  posts             Post[]
  reviewItems       ReviewItem[]
  // better-auth organization plugin: membership and invitations sent.
  orgMemberships  Member[]
  sentInvitations Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // admin plugin
  impersonatedBy String?

  // organization plugin: the org the session is currently acting in.
  activeOrganizationId String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model RateLimit {
  id          String @id
  key         String @unique
  count       Int
  // better-auth stores this as a JS epoch milliseconds value (bigint: true).
  lastRequest BigInt

  @@map("rateLimit")
}

// ---------------------------------------------------------------------------
// Domain
// ---------------------------------------------------------------------------

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
}

/// Ordered easiest to hardest. The leaderboard weights points by this ladder.
enum Difficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum SessionStatus {
  GENERATING
  READY
  SUBMITTED
  GRADED
  FAILED
  ABANDONED
}

/// Why a session exists. CUSTOM is the classic configurator flow; the others
/// change where its questions come from and which surfaces show it.
enum SessionMode {
  CUSTOM
  /// Generated from an extracted job-description brief.
  JOB_DESCRIPTION
  /// An attempt at today's shared DailyChallenge question set.
  DAILY
  /// Regenerated questions targeting the user's due ReviewItems.
  REVIEW
  /// A clone of another session's questions, taken via its share link.
  REMATCH
  /// A candidate attempt at an organization's Assessment.
  ASSESSMENT
}

/// An attempt at a quiz/interview.
///
/// userId is null when it was taken signed-out: such a session is reachable by
/// anyone holding its id — the random UUID is the capability. Once a session
/// belongs to a user it is theirs alone. See canAccessSession() in the DAL.
model InterviewSession {
  id          String        @id @default(uuid())
  userId      String?
  /// Unguessable public id; null until the user opts into sharing.
  shareId     String?       @unique
  topic       String        @db.VarChar(120)
  difficulty  Difficulty
  status      SessionStatus @default(GENERATING)
  /// Total questions requested. Persisted so a partially-generated session
  /// still knows its target.
  questionCount Int
  timeLimitMs Int?
  /// Server-authoritative deadline. The client timer is decoration; this is
  /// what submit() enforces.
  expiresAt   DateTime?     @db.Timestamptz(3)
  startedAt   DateTime?     @db.Timestamptz(3)
  submittedAt DateTime?     @db.Timestamptz(3)
  gradedAt    DateTime?     @db.Timestamptz(3)
  /// Percentage 0-100. Decimal, never Float — this is a user-visible grade.
  score       Decimal?      @db.Decimal(5, 2)
  /// Populated when status = FAILED so the UI can explain itself.
  error       String?

  mode        SessionMode   @default(CUSTOM)
  /// Adaptive sessions step per-batch difficulty from answer signal; the
  /// session-level `difficulty` is then just the starting rung.
  adaptive    Boolean       @default(false)
  /// Extra focus text fed to the generator: the extracted JD profile
  /// (JOB_DESCRIPTION) or the due-concept list (REVIEW). Always our own
  /// extraction output, never a raw user paste.
  brief       String?       @db.VarChar(2000)

  dailyChallengeId String?
  /// REMATCH: the session whose question set this one cloned.
  rematchOfId      String?
  /// ASSESSMENT: the org assessment this candidate attempt belongs to.
  assessmentId     String?
  candidateName    String?  @db.VarChar(80)
  candidateEmail   String?  @db.VarChar(160)
  /// Focus-loss/paste counters, captured for ASSESSMENT sessions only and shown
  /// only to the assessment's organization.
  integrity        Json?    @db.JsonB

  createdAt   DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(3)

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]
  aiCalls   AiCall[]

  dailyChallenge DailyChallenge?    @relation(fields: [dailyChallengeId], references: [id], onDelete: SetNull)
  rematchOf      InterviewSession?  @relation("Rematch", fields: [rematchOfId], references: [id], onDelete: SetNull)
  rematches      InterviewSession[] @relation("Rematch")
  assessment     Assessment?        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([dailyChallengeId, score(sort: Desc)])
  @@index([assessmentId, createdAt(sort: Desc)])
  @@map("interview_session")
}

/// A generated question. `answerKey` and `explanation` are secret until the
/// session is graded — see toClientQuestion() in the DAL.
model Question {
  id          String       @id @default(uuid())
  sessionId   String
  index       Int
  type        QuestionType
  prompt      String
  /// MCQ only: [{ key: "a", text: "..." }]. Null for TRUE_FALSE/SHORT_ANSWER.
  choices     Json?        @db.JsonB
  /// MCQ: { key: "a" } · TRUE_FALSE: { value: true } · SHORT_ANSWER:
  /// { expected: "...", keyPoints: [...] }. NEVER sent to the client pre-grading.
  answerKey   Json         @db.JsonB
  explanation String?
  /// Concept tags driving the weakness rollup in analytics.
  concepts    String[]
  /// Set on adaptive sessions, where each batch can sit on a different rung.
  /// Null means "the session's difficulty".
  difficulty  Difficulty?

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer  Answer?

  @@unique([sessionId, index])
  @@map("question")
}

model Answer {
  id         String   @id @default(uuid())
  questionId String   @unique
  /// MCQ: { key: "a" } · TRUE_FALSE: { value: true } · SHORT_ANSWER: { text: "..." }
  response   Json     @db.JsonB
  isCorrect  Boolean?
  /// 0-100. Supports partial credit on short answers.
  score      Decimal? @db.Decimal(5, 2)
  feedback   String?
  /// Active time the user spent on this question, summed across visits.
  /// Client-reported, so it is analytics-grade data, never an enforcement input.
  timeMs     Int?
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answer")
}

/// One row per DeepSeek request: cost, latency, and prefix-cache effectiveness.
/// Written via after() so tracking never delays a response.
model AiCall {
  id                    String   @id @default(uuid())
  sessionId             String?
  model                 String
  /// "generate" | "grade"
  purpose               String
  promptCacheHitTokens  Int      @default(0)
  promptCacheMissTokens Int      @default(0)
  outputTokens          Int      @default(0)
  costUsd               Decimal  @default(0) @db.Decimal(10, 6)
  latencyMs             Int
  ok                    Boolean
  errorCode             String?
  attempts              Int      @default(1)
  createdAt             DateTime @default(now()) @db.Timestamptz(3)

  session InterviewSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([ok])
  @@map("ai_call")
}

// ---------------------------------------------------------------------------
// Learning loop
// ---------------------------------------------------------------------------

/// One concept a signed-in user got wrong, scheduled for re-testing at
/// expanding intervals (1d → 3d → 7d, then retired). Review sessions generate
/// *fresh* questions targeting due concepts — the original question is never
/// repeated verbatim.
model ReviewItem {
  id         String     @id @default(uuid())
  userId     String
  concept    String     @db.VarChar(120)
  /// The topic the concept was missed under; review generation groups by it.
  topic      String     @db.VarChar(120)
  difficulty Difficulty
  /// 0, 1, 2 index into the interval ladder. Advances on a correct review
  /// answer, resets (and counts a lapse) on another miss.
  stage      Int        @default(0)
  lapses     Int        @default(0)
  dueAt      DateTime   @db.Timestamptz(3)
  /// Set once the ladder is climbed; retired items stop appearing in the queue
  /// but keep their history for the mastery view.
  retired    Boolean    @default(false)
  createdAt  DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime   @updatedAt @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic, concept])
  @@index([userId, retired, dueAt])
  @@map("review_item")
}

/// One shared question set per UTC day. Generated by the first visitor (under
/// an advisory lock, same pattern as the admin claim); every attempt copies
/// these frozen payloads into its own Question rows so grading is unchanged.
model DailyChallenge {
  id         String     @id @default(uuid())
  /// UTC YYYY-MM-DD.
  dateKey    String     @unique @db.VarChar(10)
  topic      String     @db.VarChar(120)
  difficulty Difficulty
  /// Frozen [{type, prompt, choices, answerKey, explanation, concepts}].
  /// Contains answer keys — server-only, never serialized to a client.
  questions  Json       @db.JsonB
  createdAt  DateTime   @default(now()) @db.Timestamptz(3)

  sessions InterviewSession[]

  @@map("daily_challenge")
}

// ---------------------------------------------------------------------------
// Organizations & assessments
// ---------------------------------------------------------------------------

/// Owned by the better-auth `organization` plugin. Its columns (name, slug,
/// logo, metadata, createdAt) are written by better-auth; `assessments` is ours.
/// There is no `ownerId` — ownership is the Member with role "owner" that the
/// plugin creates for the creator. The "3 owned orgs" cap is enforced in the
/// action by counting owner-role memberships.
model Organization {
  id       String  @id
  name     String  @db.VarChar(80)
  /// URL segment, unique — the org's public identity in /org/[slug].
  slug     String  @unique @db.VarChar(80)
  logo     String?
  metadata String?
  createdAt DateTime @default(now())

  members     Member[]
  invitations Invitation[]
  assessments Assessment[]

  @@map("organization")
}

/// better-auth `organization` plugin member. Role is "owner" | "admin" |
/// "member", checked in the org DAL, not here.
model Member {
  id             String   @id
  organizationId String
  userId         String
  role           String   @default("member") @db.VarChar(20)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("member")
}

/// better-auth `organization` plugin invitation. Pending invites to join an org
/// by email; status is "pending" | "accepted" | "rejected" | "canceled".
model Invitation {
  id             String   @id
  organizationId String
  email          String
  role           String?
  status         String   @default("pending")
  expiresAt      DateTime
  inviterId      String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

/// A screening interview an organization sends to candidates. The question set
/// is generated once and frozen so every candidate answers the identical set.
model Assessment {
  id            String     @id @default(uuid())
  orgId         String
  title         String     @db.VarChar(120)
  topic         String     @db.VarChar(120)
  difficulty    Difficulty
  questionCount Int
  timeLimitMs   Int?
  /// Frozen [{type, prompt, choices, answerKey, explanation, concepts}].
  /// Contains answer keys — server-only, never serialized to a client.
  questions     Json       @db.JsonB
  /// Capability token for the public invite link. Unguessable; rotating it
  /// revokes every outstanding invite at once.
  inviteToken   String     @unique
  /// Inactive assessments refuse new candidates but keep their reports.
  active        Boolean    @default(true)
  createdById   String?
  createdAt     DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(3)

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions     InterviewSession[]

  @@index([orgId, createdAt(sort: Desc)])
  @@map("assessment")
}

// ---------------------------------------------------------------------------
// Content
// ---------------------------------------------------------------------------

enum PostStatus {
  DRAFT
  PUBLISHED
}

/// A blog post, authored in /admin.
///
/// `body` is Markdown, never HTML, and is rendered with raw HTML disabled — a
/// stored-XSS on a public page is the obvious way for this feature to go wrong.
model Post {
  id        String     @id @default(uuid())
  /// URL segment. Unique because it is the public identity of the post.
  slug      String     @unique @db.VarChar(120)
  title     String     @db.VarChar(160)
  /// Shown in listings and as the meta description.
  excerpt   String     @db.VarChar(320)
  body      String
  status    PostStatus @default(DRAFT)
  /// Set the first time it is published; keeps its original date on re-publish.
  publishedAt DateTime? @db.Timestamptz(3)
  authorId  String?
  createdAt DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt DateTime   @updatedAt @db.Timestamptz(3)

  /// SetNull, not Cascade: deleting the author must not delete the writing.
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt(sort: Desc)])
  @@map("post")
}

/// A message from the contact form. Read in /admin — there is no mail provider.
model ContactMessage {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(80)
  email     String   @db.VarChar(160)
  subject   String   @db.VarChar(160)
  body      String   @db.VarChar(4000)
  /// Marked by an admin once dealt with; this is the whole workflow.
  handled   Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  @@index([handled, createdAt(sort: Desc)])
  @@map("contact_message")
}
